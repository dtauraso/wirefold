{
  "name": "topology-vscode",
  "displayName": "Topology Editor",
  "description": "Drag-and-drop editor for topology.json (wirefold)",
  "version": "0.0.1",
  "publisher": "dtauraso",
  "private": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "customEditors": [
      {
        "viewType": "topology.editor",
        "displayName": "Topology Editor",
        "selector": [
          {
            "filenamePattern": "**/*topology.json"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "gen:node-defs": "go run ../../tools/gen-node-defs",
    "build": "npm run gen:node-defs && node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:tier4": "PLAYWRIGHT_TIER4=1 playwright test --project=tier4-latency",
    "package": "vsce package"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.3.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "immer": "^11.1.4",
    "lit-html": "^3.3.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hotkeys-hook": "^5.3.0",
    "three": "^0.184.0",
    "use-debounce": "^10.1.1",
    "zustand": "^5.0.12"
  }
}
