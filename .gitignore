# Stray cmd/pseudo build output at repo root (normal path is `go run ./cmd/pseudo`).
# Anchored so it does not match the tools/pseudo or cmd/pseudo source dirs.
/pseudo

# Prerequisites
*.d

# Object files
*.o
*.ko
*.obj
*.elf

# Linker output
*.ilk
*.map
*.exp

# Precompiled Headers
*.gch
*.pch

# Libraries
*.lib
*.a
*.la
*.lo

# Shared objects (inc. Windows DLLs)
*.dll
*.so
*.so.*
*.dylib

# Executables
*.exe
*.out
*.app
*.i*86
*.x86_64
*.hex

# Debug files
*.dSYM/
*.su
*.idb
*.pdb

# Kernel Module Compile Results
*.mod*
*.cmd
.tmp_versions/
modules.order
Module.symvers
Mkfile.old
dkms.conf

# Node / topology-editor
node_modules/
dist/
.vite/
tools/topology-vscode/out/
tools/topology-vscode/playwright-report/
tools/topology-vscode/e2e/tier4/.tmp/
tools/topology-vscode/test-results/

# Local dev binaries (build outputs from go build at project root)
/topogen
/topogend
# go build output if accidentally run from the tools/topology-vscode dir
tools/topology-vscode/gen-node-defs
# compiled gen-node-defs binary (build artifact); source is tools/gen-node-defs/
/gen-node-defs

# Local working notes / scratch
/notes/
/cascade-parity-plan.md
/plugin-code-smells.md

# topogend session token (autogenerated, owner-readable)
/.topogend-token

# Pulse-probe dump from the visual editor's webview (workspace-local, transient)
/.probe/

# Prebuilt Go binary cache (built once by the editor runner; not for VCS)
/.wirefold-cache/

# Scene sidecar — gitignored so camera/label state does not generate commit noise.
# Diagram state (positions, fades) stays in topology.json.
/topology.scene.json

# Tree-topology scene sidecar (auto-written by Go on each run; not for VCS).
/topology/view/scene.json
/topology/view/scene.json.tmp

# One-file-per-writer split of the scene sidecar above: each of these has exactly ONE
# writer, which is what let sceneFileMu be deleted rather than narrowed. camera/overlays/
# sphere are the same kind of auto-written, locally-preferred view state scene.json was —
# not for VCS.
# nodes/<id>/position.json and local-polars.json are NOT listed here: they carry the same
# authoritative per-node data meta.json does (which IS tracked), so they stay trackable too.
/topology/view/camera.json
/topology/view/camera.json.tmp
/topology/view/overlays.json
/topology/view/overlays.json.tmp
/topology/view/sphere.json
/topology/view/sphere.json.tmp

# Hook block log (local audit trail, not for VCS)
.claude/hooks/go-blocks.log

# Editor settings
.vscode/

# macOS
.DS_Store

.claude/scheduled_tasks.lock

# Agent worktrees (temporary, per-agent scratch checkouts)
.claude/worktrees/

# Human worktrees container (one branch per subfolder, shares this .git)
/worktrees/
